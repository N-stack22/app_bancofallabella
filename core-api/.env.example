# FastAPI Core Mobile - Banco Falabella
# En local puede ser PostgreSQL local o Supabase Transaction Pooler.
# Supabase recomendado: Settings > Database > Connection string > Transaction pooler.
# Formato compatible con SQLAlchemy/psycopg2:
# postgresql+psycopg2://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

DATABASE_URL=postgresql+psycopg2://postgres.PROJECT_REF:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
SECRET_KEY=cambia_esta_clave_segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORE_BACKEND_URL=http://localhost:8001
CORE_DATABASE_URL=
PORT=8003
